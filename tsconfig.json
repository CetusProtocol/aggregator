{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist/",
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["node_modules/**/*", "dist/**/*", "tests/**/*", "**/*.spec.ts", "**/*.test.ts"]
}
